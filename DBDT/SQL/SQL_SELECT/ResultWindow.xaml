<Window x:Class="DBDT.SQL.SQL_SELECT.ResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Result" Height="768" Width="1024" SizeToContent="Width" WindowStartupLocation="CenterScreen">
    <Grid>
        <DataGrid Name="resultGrid" AutoGenerateColumns="True" SelectionUnit="Cell" >
             <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Kopiuj z warunkiem where" Click="resultGrid_Click" />
                    <Separator/>
                    <MenuItem Header="Kopiuj z warunkiem select -> where" Click="resultGrid_select_Click" />
                </ContextMenu>
            </DataGrid.ContextMenu>
        </DataGrid>
    </Grid>
</Window>
