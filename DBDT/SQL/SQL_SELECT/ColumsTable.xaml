<Window x:Class="DBDT.SQL.SQL_SELECT.ColumsTable"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DBDT.SQL.SQL_SELECT"
        mc:Ignorable="d"
        Title="ColumsTable" Height="460" Width="305" Topmost="True" ResizeMode="NoResize" InputScope="Default" WindowStyle="None">
    <Grid>
        <ListBox Name="itContr"  ItemsSource="{Binding MyItems}" SelectionMode="Multiple" Margin="0,0,0,55">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="IsSelected" Value="{Binding Path=IsChecked, Mode=TwoWay}" />
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <CheckBox IsChecked="{Binding IsChecked}"  Content="{Binding}" />
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Button Content="Zakończ" HorizontalAlignment="Center" Height="30" Margin="0,410,0,0" VerticalAlignment="Top" Width="285" Click="Click_Close"/>

    </Grid>
</Window>
